# ============================================================
# .env.example — copy to .env and fill in real values
# ============================================================

# --- Docker Compose (local / staging) -----------------------
# Host port mapped to Nginx (default 80)
HOST_PORT=80

# --- Express API server -------------------------------------
NODE_ENV=production
PORT=3001
REDIS_URL=redis://redis:6379
ALLOWED_ORIGIN=http://localhost
DB_DIR=/data/db

# --- Next.js frontend ---------------------------------------
# Internal Docker network URL (server → express)
SERVER_URL=http://server:3001

# --- AWS (Terraform / production) ---------------------------
# AWS region
AWS_REGION=ap-northeast-1

# ECR repository URIs (filled after `terraform apply`)
ECR_SERVER_URI=
ECR_FRONTEND_URI=
ECR_NGINX_URI=

# ECS cluster name
ECS_CLUSTER_NAME=nindou

# ElastiCache Redis primary endpoint (filled after `terraform apply`)
ELASTICACHE_ENDPOINT=

# CloudFront distribution domain (filled after `terraform apply`)
CLOUDFRONT_DOMAIN=

# Optional: override ALLOWED_ORIGIN in production
# ALLOWED_ORIGIN=https://your-domain.example.com
